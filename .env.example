NODE_ENV="development"
PORT="4000"
JWT_SECRET="replace-this-with-a-long-random-secret"
JWT_EXPIRES_IN_SECONDS="86400"

# Comma-separated allowed frontend origins for credentialed CORS.
CORS_ORIGINS="http://localhost:3000"

# Cookie sameSite values: lax | strict | none
COOKIE_SAME_SITE="lax"

# Public sign-up should remain false for internal organization apps.
ALLOW_SELF_REGISTER="false"

# Login lockout controls
MAX_FAILED_LOGIN_ATTEMPTS="5"
LOGIN_LOCKOUT_MINUTES="15"

# Rate limiter shared window (applies to all tiers)
RATE_LIMIT_WINDOW_MS="900000"

# Sensitive tier: login, accept-invite (brute-force targets)
SENSITIVE_RATE_LIMIT_MAX="10"

# Standard tier: general authenticated API routes
STANDARD_RATE_LIMIT_MAX="100"

# Strict tier: password reset, OTP (future)
STRICT_RATE_LIMIT_MAX="5"

# Invite expiry in days
INVITE_EXPIRY_DAYS="7"