# API base URL for the frontend to communicate with the backend.
# Leave this blank during local development to use the Vite proxy.
# Production example: https://your-backend.example.com
VITE_API_BASE_URL=http://localhost:4000

# Set to "true" once OIDC env vars are configured in the backend (OIDC_ISSUER_URL, OIDC_CLIENT_ID, etc.)
VITE_SSO_ENABLED=false
