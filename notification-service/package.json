    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.1",
