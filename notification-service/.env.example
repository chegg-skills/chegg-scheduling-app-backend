# ---------------------------------------------------------
# DATABASE CONFIGURATION
# ---------------------------------------------------------
# Local: postgresql://user:pass@localhost:5432/notification_db
# Production: (Use your Render External Database URL)
DATABASE_URL="postgresql://user:pass@localhost:5432/notification_db"

# ---------------------------------------------------------
# MESSAGING (RABBITMQ)
# ---------------------------------------------------------
# Local: amqp://localhost
# Production: (Use your CloudAMQP URL)
RABBITMQ_URL="amqp://localhost"

# ---------------------------------------------------------
# EMAIL (SMTP)
# ---------------------------------------------------------
# Production: (e.g., your SendGrid or Gmail username)
EMAIL_USERNAME="your-email@example.com"
EMAIL_PASSWORD="your-app-password"

# Required for Render Web Service health checks (Free Tier)
PORT=10001
NODE_ENV=production

# ---------------------------------------------------------
# OBSERVABILITY
# ---------------------------------------------------------
# Sentry error tracking (optional — leave empty to disable)
# Production: copy the DSN from your Sentry project settings
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
