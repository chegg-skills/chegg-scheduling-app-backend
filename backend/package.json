{
  "name": "chegg-scheduling-app-backend",
  "version": "1.0.0",
  "description": "Backend API for the organization meeting scheduling app.",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "seed:demo": "tsx src/scripts/populate-data.ts",
    "seed:demo:reset": "RESET_DEMO_DATA=true tsx src/scripts/populate-data.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:unit": "jest --runInBand --testPathPattern=tests/unit",
    "test:integration": "jest --runInBand --testPathPattern=tests/integration",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.6.0",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.5.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
