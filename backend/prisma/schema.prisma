generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                      @id @default(uuid())
  email                  String                      @unique
  password               String?
  role                   UserRole
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  avatarUrl              String?
  firstName              String
  isActive               Boolean                     @default(true)
  lastLoginAt            DateTime?
  lastName               String
  phoneNumber            String?
  timezone               String                      @default("UTC")
  failedLoginAttempts    Int                         @default(0)
  lockedUntil            DateTime?
  country                String?
  preferredLanguage      String                      @default("en")
  zoomIsvLink            String?
  publicBookingSlug      String                      @unique
  ssoProvider            String?
  ssoSub                 String?
  ssoLinkedAt            DateTime?
  bookings               Booking[]
  eventsCreated          Event[]                     @relation("EventCreatedBy")
  eventsUpdated          Event[]                     @relation("EventUpdatedBy")
  coachedEvents          EventCoach[]                @relation("EventCoachUser")
  createdEventOfferings  EventOffering[]             @relation("EventOfferingCreatedBy")
  updatedEventOfferings  EventOffering[]             @relation("EventOfferingUpdatedBy")
  slotAssignments        EventScheduleSlot[]         @relation("SlotCoach")
  sessionLogs            SessionLog[]                @relation("SessionLogLoggedBy")
  teamsCreated           Team[]                      @relation("TeamCreatedBy")
  teamsLed               Team[]                      @relation("TeamLead")
  teamMemberships        TeamMember[]
  availabilityExceptions UserAvailabilityException[]
  weeklyAvailability     UserWeeklyAvailability[]

  @@unique([ssoProvider, ssoSub])
}

model Team {
  id                String       @id @default(uuid())
  name              String       @unique
  description       String?
  isActive          Boolean      @default(true)
  teamLeadId        String
  createdById       String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  publicBookingSlug String       @unique
  bookings          Booking[]
  events            Event[]
  createdByUser     User         @relation("TeamCreatedBy", fields: [createdById], references: [id])
  teamLead          User         @relation("TeamLead", fields: [teamLeadId], references: [id])
  members           TeamMember[]
}

model UserInvite {
  id          String    @id @default(uuid())
  email       String
  role        UserRole
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  requiresSso Boolean   @default(false)
}

model OidcState {
  id          String   @id @default(uuid())
  state       String   @unique
  nonce       String
  inviteToken String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId, isActive])
}

model EventOffering {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
  createdBy   User     @relation("EventOfferingCreatedBy", fields: [createdById], references: [id])
  updatedBy   User     @relation("EventOfferingUpdatedBy", fields: [updatedById], references: [id])

  @@index([isActive, sortOrder])
}

model Event {
  id                        String                    @id @default(uuid())
  name                      String
  description               String?
  offeringId                String
  assignmentStrategy        AssignmentStrategy        @default(DIRECT)
  durationSeconds           Int
  locationType              EventLocationType
  locationValue             String
  isActive                  Boolean                   @default(true)
  teamId                    String
  createdById               String
  updatedById               String
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  publicBookingSlug         String                    @unique
  bookingMode               EventBookingMode          @default(COACH_AVAILABILITY)
  allowedWeekdays           Int[]                     @default([])
  minimumNoticeMinutes      Int                       @default(0)
  minParticipantCount       Int?
  maxParticipantCount       Int?
  sessionLeadershipStrategy SessionLeadershipStrategy @default(SINGLE_COACH)
  bufferAfterMinutes        Int                       @default(0)
  interactionType           InteractionType
  fixedLeadCoachId          String?
  maxCoachCount             Int?
  minCoachCount             Int                       @default(1)
  showDescription           Boolean                   @default(false)
  targetCoHostCount         Int?
  maxBookingWindowDays      Int?
  bookings                  Booking[]
  createdBy                 User                      @relation("EventCreatedBy", fields: [createdById], references: [id])
  offering                  EventOffering             @relation(fields: [offeringId], references: [id])
  team                      Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  updatedBy                 User                      @relation("EventUpdatedBy", fields: [updatedById], references: [id])
  weeklyAvailability        EventWeeklyAvailability[]
  coaches                   EventCoach[]
  routingState              EventRoutingState?
  scheduleSlots             EventScheduleSlot[]

  @@index([teamId, isActive])
  @@index([offeringId])
  @@index([interactionType])
  @@index([assignmentStrategy])
  @@index([bookingMode])
}

model EventCoach {
  id          String   @id @default(uuid())
  eventId     String
  coachUserId String
  coachOrder  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  coachUser   User     @relation("EventCoachUser", fields: [coachUserId], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, coachUserId])
  @@unique([eventId, coachOrder])
  @@index([coachUserId])
  @@index([eventId, isActive])
}

model EventRoutingState {
  id             String   @id @default(uuid())
  eventId        String   @unique
  nextCoachOrder Int      @default(1)
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventScheduleSlot {
  id                String      @id @default(uuid())
  eventId           String
  startTime         DateTime
  endTime           DateTime
  capacity          Int?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  assignedCoachId   String?
  recurrenceGroupId String?
  bookings          Booking[]
  sessionLog        SessionLog?
  assignedCoach     User?       @relation("SlotCoach", fields: [assignedCoachId], references: [id])
  event             Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, startTime])
  @@index([eventId, startTime, isActive])
  @@index([assignedCoachId])
  @@index([recurrenceGroupId])
}

model SessionLog {
  id              String              @id @default(uuid())
  scheduleSlotId  String              @unique
  loggedByUserId  String
  topicsDiscussed String?
  summary         String?
  coachNotes      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  scheduleSlot    EventScheduleSlot   @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  loggedBy        User                @relation("SessionLogLoggedBy", fields: [loggedByUserId], references: [id])
  attendance      SessionAttendance[]

  @@index([scheduleSlotId])
  @@index([loggedByUserId])
}

model SessionAttendance {
  id           String     @id @default(uuid())
  sessionLogId String
  bookingId    String     @unique
  attended     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessionLog   SessionLog @relation(fields: [sessionLogId], references: [id], onDelete: Cascade)
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([sessionLogId])
}

model EventWeeklyAvailability {
  id        String   @id @default(uuid())
  eventId   String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, dayOfWeek])
}

model UserWeeklyAvailability {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
}

model UserAvailabilityException {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime
  isUnavailable Boolean
  startTime     String?
  endTime       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Student {
  id            String    @id @default(uuid())
  fullName      String
  email         String    @unique
  firstBookedAt DateTime?
  lastBookedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]

  @@index([lastBookedAt])
}

model Booking {
  id                String             @id @default(uuid())
  studentName       String
  studentEmail      String
  teamId            String
  eventId           String
  startTime         DateTime
  endTime           DateTime
  timezone          String             @default("UTC")
  notes             String?
  status            BookingStatus      @default(CONFIRMED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessionObjectives String?
  specificQuestion  String?
  triedSolutions    String?
  usedResources     String?
  meetingJoinUrl    String?
  studentId         String?
  scheduleSlotId    String?
  rescheduleToken   String?            @unique @default(uuid())
  coCoachUserIds    String[]           @default([])
  coachUserId       String
  coach                User               @relation(fields: [coachUserId], references: [id])
  event                Event              @relation(fields: [eventId], references: [id])
  scheduleSlot         EventScheduleSlot? @relation(fields: [scheduleSlotId], references: [id])
  student              Student?           @relation(fields: [studentId], references: [id])
  team                 Team               @relation(fields: [teamId], references: [id])
  sessionAttendance    SessionAttendance?

  @@index([studentId])
  @@index([scheduleSlotId])
  @@index([teamId])
  @@index([eventId])
  @@index([coachUserId])
  @@index([startTime, endTime])
}

enum UserRole {
  SUPER_ADMIN
  TEAM_ADMIN
  COACH
}

enum AssignmentStrategy {
  DIRECT
  ROUND_ROBIN
}

enum EventLocationType {
  VIRTUAL
  IN_PERSON
  CUSTOM
}

enum EventBookingMode {
  COACH_AVAILABILITY
  FIXED_SLOTS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SessionLeadershipStrategy {
  SINGLE_COACH
  FIXED_LEAD
  ROTATING_LEAD
}

enum InteractionType {
  ONE_TO_ONE
  ONE_TO_MANY
  MANY_TO_ONE
  MANY_TO_MANY
}
