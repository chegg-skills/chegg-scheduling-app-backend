generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                      @id @default(uuid())
  email                  String                      @unique
  password               String?
  role                   UserRole
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  avatarUrl              String?
  firstName              String
  isActive               Boolean                     @default(true)
  lastLoginAt            DateTime?
  lastName               String
  phoneNumber            String?
  timezone               String                      @default("UTC")
  failedLoginAttempts    Int                         @default(0)
  lockedUntil            DateTime?
  country                String?
  preferredLanguage      String                      @default("en")
  zoomIsvLink              String?
  zoomIsvLinkExpiresAt     DateTime?
  zoomIsvLinkReminderDays  Int?
  publicBookingSlug        String                      @unique
  ssoProvider            String?
  ssoSub                 String?
  ssoLinkedAt            DateTime?
  bookings               Booking[]
  eventsCreated          Event[]                     @relation("EventCreatedBy")
  eventsUpdated          Event[]                     @relation("EventUpdatedBy")
  coachedEvents          EventCoach[]                @relation("EventCoachUser")
  slotAssignments        EventScheduleSlot[]         @relation("SlotCoach")
  createdEventTypes      EventType[]                 @relation("EventTypeCreatedBy")
  updatedEventTypes      EventType[]                 @relation("EventTypeUpdatedBy")
  sessionLogs            SessionLog[]                @relation("SessionLogLoggedBy")
  teamsCreated           Team[]                      @relation("TeamCreatedBy")
  teamsLed               Team[]                      @relation("TeamLead")
  teamMemberships        TeamMember[]
  eventGroupsCreated     EventGroup[]                @relation("EventGroupCreatedBy")
  availabilityExceptions UserAvailabilityException[]
  weeklyAvailability     UserWeeklyAvailability[]
  communicationsSent     StudentCommunicationLog[]
  createdBookingDirectories BookingDirectory[]          @relation("BookingDirectoryCreatedBy")
  updatedBookingDirectories BookingDirectory[]          @relation("BookingDirectoryUpdatedBy")
  invitesCreated            UserInvite[]                @relation("InviteCreatedBy")
  activitiesPerformed       BookingActivity[]           @relation("ActivityActorUser")

  @@unique([ssoProvider, ssoSub])
}

model Team {
  id                 String                  @id @default(uuid())
  name               String                  @unique
  description        String?
  isActive           Boolean                 @default(true)
  teamLeadId         String
  createdById        String
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  publicBookingSlug  String                  @unique
  deletedAt          DateTime?
  bookings           Booking[]
  events             Event[]
  eventGroups        EventGroup[]
  createdByUser      User                    @relation("TeamCreatedBy", fields: [createdById], references: [id])
  teamLead           User                    @relation("TeamLead", fields: [teamLeadId], references: [id])
  members            TeamMember[]
  notificationConfig TeamNotificationConfig?
  bookingDirectoryTeams BookingDirectoryTeam[]
}

model UserInvite {
  id          String    @id @default(uuid())
  email       String
  role        UserRole
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  requiresSso Boolean   @default(false)

  createdByUser User @relation("InviteCreatedBy", fields: [createdBy], references: [id])

  @@index([email])
}

model OidcState {
  id          String   @id @default(uuid())
  state       String   @unique
  nonce       String
  inviteToken String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId, isActive])
}

model EventType {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  color       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
  bookingDirectorySections BookingDirectorySection[]
  createdBy   User     @relation("EventTypeCreatedBy", fields: [createdById], references: [id])
  updatedBy   User     @relation("EventTypeUpdatedBy", fields: [updatedById], references: [id])

  @@index([isActive, sortOrder])
}

model Event {
  id                        String                    @id @default(uuid())
  name                      String
  description               String?
  eventTypeId               String?
  assignmentStrategy        AssignmentStrategy        @default(DIRECT)
  durationSeconds           Int
  locationType              EventLocationType
  locationValue             String
  isActive                  Boolean                   @default(true)
  teamId                    String
  createdById               String
  updatedById               String
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  publicBookingSlug         String                    @unique
  bookingMode               EventBookingMode          @default(COACH_AVAILABILITY)
  minimumNoticeMinutes      Int                       @default(0)
  maxParticipantCount       Int?
  sessionLeadershipStrategy SessionLeadershipStrategy @default(SINGLE_COACH)
  bufferAfterMinutes        Int                       @default(0)
  interactionType           InteractionType
  fixedLeadCoachId          String?
  showDescription           Boolean                   @default(false)
  targetCoHostCount         Int?
  maxBookingWindowDays      Int?
  deferCoachReveal          Boolean                   @default(false)
  allowStudentCoachChoice   Boolean                   @default(false)
  allowAnonymousBooking     Boolean                   @default(false)
  meetingLinkSource         MeetingLinkSource         @default(COACH_ISV)
  locationLinkExpiresAt     DateTime?
  locationLinkReminderDays  Int?
  customQuestions           String[]                  @default([])
  useDefaultQuestions       Boolean                   @default(true)
  groupId                   String?
  deletedAt                 DateTime?
  bookings                  Booking[]
  createdBy                 User                      @relation("EventCreatedBy", fields: [createdById], references: [id])
  eventType                 EventType?                @relation(fields: [eventTypeId], references: [id], onDelete: SetNull)
  group                     EventGroup?               @relation(fields: [groupId], references: [id], onDelete: Restrict)
  team                      Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  updatedBy                 User                      @relation("EventUpdatedBy", fields: [updatedById], references: [id])
  coaches                   EventCoach[]
  routingState              EventRoutingState?
  scheduleSlots             EventScheduleSlot[]
  recurrenceGroups          RecurrenceGroup[]

  @@index([teamId, isActive])
  @@index([eventTypeId])
  @@index([interactionType])
  @@index([assignmentStrategy])
  @@index([bookingMode])
  @@index([groupId])
}

model EventGroup {
  id                String   @id @default(uuid())
  teamId            String
  name              String
  description       String?
  color             String?
  createdById       String
  publicBookingSlug String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdByUser     User     @relation("EventGroupCreatedBy", fields: [createdById], references: [id])
  events            Event[]

  @@unique([teamId, name])
  @@index([teamId])
}

model EventCoach {
  id          String   @id @default(uuid())
  eventId     String
  coachUserId String
  coachOrder  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  coachUser   User     @relation("EventCoachUser", fields: [coachUserId], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  weeklyAvailabilityOverride EventCoachWeeklyAvailability[]

  @@unique([eventId, coachUserId])
  @@unique([eventId, coachOrder])
  @@index([coachUserId])
  @@index([eventId, isActive])
}

model EventCoachWeeklyAvailability {
  id          String   @id @default(uuid())
  eventId     String
  coachUserId String
  dayOfWeek   Int
  startTime   String
  endTime     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  eventCoach  EventCoach @relation(fields: [eventId, coachUserId], references: [eventId, coachUserId], onDelete: Cascade)

  @@index([eventId, coachUserId, dayOfWeek])
}

model EventRoutingState {
  id             String   @id @default(uuid())
  eventId        String   @unique
  nextCoachOrder Int      @default(1)
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventScheduleSlot {
  id                String      @id @default(uuid())
  eventId           String
  startTime         DateTime
  endTime           DateTime
  capacity          Int?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  assignedCoachId   String?
  recurrenceGroupId String?
  isCancelled            Boolean     @default(false)
  assignedCoachOverride  Boolean     @default(false)
  coachRevealSentAt      DateTime?
  sessionJoinUrl         String?
  bookings          Booking[]
  assignedCoach     User?       @relation("SlotCoach", fields: [assignedCoachId], references: [id])
  event             Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recurrenceGroup   RecurrenceGroup? @relation(fields: [recurrenceGroupId], references: [id], onDelete: SetNull)
  sessionLog        SessionLog?

  @@unique([eventId, startTime])
  @@index([eventId, startTime, isActive])
  @@index([assignedCoachId])
  @@index([recurrenceGroupId])
}

model RecurrenceGroup {
  id                        String              @id @default(uuid())
  eventId                   String
  frequency                 String
  isContinuous              Boolean             @default(false)
  isActive                  Boolean             @default(true)
  recurrenceVisibilityLimit Int?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  event                     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  slots                     EventScheduleSlot[]

  @@index([eventId])
}

model SessionLog {
  id              String              @id @default(uuid())
  scheduleSlotId  String?             @unique
  bookingId       String?             @unique
  loggedByUserId  String
  topicsDiscussed String?
  summary         String?
  coachNotes      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  attendance      SessionAttendance[]
  loggedBy        User                @relation("SessionLogLoggedBy", fields: [loggedByUserId], references: [id])
  scheduleSlot    EventScheduleSlot?  @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  booking         Booking?            @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([scheduleSlotId])
  @@index([bookingId])
  @@index([loggedByUserId])
}

model SessionAttendance {
  id           String     @id @default(uuid())
  sessionLogId String
  bookingId    String     @unique
  attended     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sessionLog   SessionLog @relation(fields: [sessionLogId], references: [id], onDelete: Cascade)

  @@index([sessionLogId])
}

model UserWeeklyAvailability {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
}

model UserAvailabilityException {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime
  isUnavailable Boolean
  startTime     String?
  endTime       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Student {
  id            String    @id @default(uuid())
  fullName      String
  email         String    @unique
  firstBookedAt DateTime?
  lastBookedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  communications StudentCommunicationLog[]

  @@index([lastBookedAt])
}

model Booking {
  id                String             @id @default(uuid())
  studentName       String
  studentEmail      String
  teamId            String
  eventId           String
  startTime         DateTime
  endTime           DateTime
  timezone          String             @default("UTC")
  notes             String?
  cancellationReason String?
  status            BookingStatus      @default(CONFIRMED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessionObjectives String?
  specificQuestion  String?
  triedSolutions    String?
  usedResources     String?
  customQuestions   String[]           @default([])
  customAnswers     String[]           @default([])
  meetingJoinUrl    String?
  studentId         String?
  scheduleSlotId    String?
  rescheduleToken   String?            @unique @default(uuid())
  sessionToken      String?            @unique @default(uuid())
  coCoachUserIds    String[]           @default([])
  coachUserId       String?
  coach             User?              @relation(fields: [coachUserId], references: [id])
  event             Event              @relation(fields: [eventId], references: [id])
  scheduleSlot      EventScheduleSlot? @relation(fields: [scheduleSlotId], references: [id])
  student           Student?           @relation(fields: [studentId], references: [id])
  team              Team               @relation(fields: [teamId], references: [id])
  sessionAttendance SessionAttendance?
  sessionLog        SessionLog?
  activities        BookingActivity[]

  @@index([studentId])
  @@index([scheduleSlotId])
  @@index([teamId])
  @@index([eventId])
  @@index([coachUserId])
  @@index([startTime, endTime])
  @@index([status])
  @@index([studentEmail])
}

/// Transactional outbox for ALL notifications. Every notification is enqueued
/// here (by publishNotificationSafely) instead of going straight to RabbitMQ; a
/// background worker publishes each row, retrying on failure. This guarantees no
/// notification is silently lost when RabbitMQ is unavailable.
model OutboxNotification {
  id              String    @id @default(cuid())
  type            String // notification type — denormalized for inspection
  payload         Json // the full NotificationPayload
  notificationKey String? // denormalized from payload, for inspection
  entityType      String?
  entityId        String?
  createdAt       DateTime  @default(now())
  claimedAt       DateTime? // lease marker for multi-worker FOR UPDATE SKIP LOCKED claim
  processedAt     DateTime?
  deadLetteredAt  DateTime?
  attempts        Int       @default(0)
  lastError       String?

  @@index([processedAt, deadLetteredAt, attempts, claimedAt])
  @@index([processedAt, createdAt]) // retention cleanup
}

// End-to-end delivery status for a notification, reported back by the notification-service
// after it actually sends (or terminally fails to send) the email. Keyed by the same
// notificationKey the publisher set, so a SENT/FAILED result can be correlated to the
// originating notification. Additive observability — does not affect any send path.
model NotificationDelivery {
  id               String    @id @default(uuid())
  notificationKey  String    @unique
  notificationType String
  status           String // "SENT" | "FAILED"
  recipient        String?
  entityType       String?
  entityId         String?
  errorMessage     String?
  deliveredAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([entityType, entityId])
}

model TeamNotificationConfig {
  id                        String   @id @default(uuid())
  teamId                    String   @unique
  team                      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reminderOffsets           Int[]    @default([1440, 60]) // minutes before session
  adminNotifyOnBooking      Boolean  @default(true)
  adminNotifyOnCancellation Boolean  @default(true)
  adminNotifyOnNoShow       Boolean  @default(true)
  coachNotifyOnBooking      Boolean  @default(true)
  coachNotifyOnCancellation Boolean  @default(true)
  coachNotifyOnNoShow       Boolean  @default(true)
  notifyLeadOnAvailability  Boolean  @default(true)
  sendFeedbackLink          Boolean  @default(false)
  feedbackFormLink          String?
  poolReminderOffsets       Int[]    @default([1440, 360])
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemBookingQuestion {
  id        String   @id @default(uuid())
  text      String   @db.VarChar(255)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookingDirectory {
  id          String                    @id @default(uuid())
  slug        String                    @unique
  name        String
  description String?
  isActive    Boolean                   @default(true)
  createdById String
  updatedById String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  sections    BookingDirectorySection[]
  createdBy   User                      @relation("BookingDirectoryCreatedBy", fields: [createdById], references: [id])
  updatedBy   User                      @relation("BookingDirectoryUpdatedBy", fields: [updatedById], references: [id])
}

model BookingDirectorySection {
  id                 String                 @id @default(uuid())
  bookingDirectoryId String
  eventTypeId        String
  sortOrder          Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  bookingDirectory   BookingDirectory       @relation(fields: [bookingDirectoryId], references: [id], onDelete: Cascade)
  eventType          EventType              @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  teams              BookingDirectoryTeam[]

  @@unique([bookingDirectoryId, eventTypeId])
  @@index([bookingDirectoryId])
  @@index([eventTypeId])
}

model BookingDirectoryTeam {
  id        String                  @id @default(uuid())
  sectionId String
  teamId    String
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())
  section   BookingDirectorySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  team      Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([sectionId, teamId])
  @@index([sectionId])
}

enum UserRole {
  SUPER_ADMIN
  TEAM_ADMIN
  COACH
}

enum AssignmentStrategy {
  DIRECT
  ROUND_ROBIN
}

enum EventLocationType {
  VIRTUAL
  IN_PERSON
  CUSTOM
}

enum EventBookingMode {
  COACH_AVAILABILITY
  FIXED_SLOTS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SessionLeadershipStrategy {
  SINGLE_COACH
  FIXED_LEAD
  ROTATING_LEAD
}

enum InteractionType {
  ONE_TO_ONE
  ONE_TO_MANY
  MANY_TO_ONE
  MANY_TO_MANY
}

enum MeetingLinkSource {
  COACH_ISV
  EVENT_LOCATION
  SESSION_LANDING_PAGE
}

enum CommunicationStatus {
  PENDING
  SENT
  FAILED
}

model StudentCommunicationLog {
  id           String              @id @default(uuid())
  studentId    String
  subject      String
  body         String              // Stores full HTML formatted email body
  status       CommunicationStatus @default(PENDING)
  errorMessage String?             // Stores delivery failure reasons if FAILED
  sentById     String
  sentAt       DateTime            @default(now())

  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sentBy       User                @relation(fields: [sentById], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sentById])
}

enum BookingActivityType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  EMAIL_SENT
  REMINDER_SENT
  BOOKING_RESCHEDULED
  BOOKING_CANCELLED
  SESSION_COMPLETED
  SESSION_NO_SHOW
  SESSION_LOGGED
  COACH_REASSIGNED
  ATTENDANCE_UPDATED
  SESSION_LOG_UPDATED
  FOLLOW_UP_BOOKED
}

enum BookingActivityActor {
  STUDENT
  COACH
  ADMIN
  SYSTEM
}

model BookingActivity {
  id           String               @id @default(uuid())
  bookingId    String
  activityType BookingActivityType
  timestamp    DateTime             @default(now())
  actorType    BookingActivityActor
  actorUserId  String?
  actorName    String?              // Denormalized actor name for historical snapshots
  metadata     Json?                // Dynamic details: e.g. { previousSlot: ..., newSlot: ..., reason: ... }

  booking      Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actorUser    User?                @relation("ActivityActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([timestamp])
}

