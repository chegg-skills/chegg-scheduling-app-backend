generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                      @id @default(uuid())
  email                   String                      @unique
  password                String
  role                    UserRole
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  avatarUrl               String?
  firstName               String
  isActive                Boolean                     @default(true)
  lastLoginAt             DateTime?
  lastName                String
  phoneNumber             String?
  timezone                String                      @default("UTC")
  failedLoginAttempts     Int                         @default(0)
  lockedUntil             DateTime?
  country                 String?
  preferredLanguage       String                      @default("en")
  zoomIsvLink             String?
  publicBookingSlug       String                      @unique
  bookings                Booking[]
  eventsCreated           Event[]                     @relation("EventCreatedBy")
  eventsUpdated           Event[]                     @relation("EventUpdatedBy")
  hostedEvents            EventHost[]                 @relation("EventHostUser")
  createdInteractionTypes EventInteractionType[]      @relation("InteractionTypeCreatedBy")
  updatedInteractionTypes EventInteractionType[]      @relation("InteractionTypeUpdatedBy")
  createdEventOfferings   EventOffering[]             @relation("EventOfferingCreatedBy")
  updatedEventOfferings   EventOffering[]             @relation("EventOfferingUpdatedBy")
  teamsCreated            Team[]                      @relation("TeamCreatedBy")
  teamsLed                Team[]                      @relation("TeamLead")
  teamMemberships         TeamMember[]
  availabilityExceptions  UserAvailabilityException[]
  weeklyAvailability      UserWeeklyAvailability[]
}

model Team {
  id                String       @id @default(uuid())
  name              String       @unique
  description       String?
  isActive          Boolean      @default(true)
  teamLeadId        String
  createdById       String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  publicBookingSlug String       @unique
  bookings          Booking[]
  events            Event[]
  createdByUser     User         @relation("TeamCreatedBy", fields: [createdById], references: [id])
  teamLead          User         @relation("TeamLead", fields: [teamLeadId], references: [id])
  members           TeamMember[]
}

model UserInvite {
  id         String    @id @default(uuid())
  email      String
  role       UserRole
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId, isActive])
}

model EventOffering {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
  createdBy   User     @relation("EventOfferingCreatedBy", fields: [createdById], references: [id])
  updatedBy   User     @relation("EventOfferingUpdatedBy", fields: [updatedById], references: [id])

  @@index([isActive, sortOrder])
}

model EventInteractionType {
  id                    String   @id @default(uuid())
  key                   String   @unique
  name                  String
  description           String?
  supportsRoundRobin    Boolean  @default(false)
  supportsMultipleHosts Boolean  @default(false)
  minHosts              Int      @default(1)
  maxHosts              Int?
  minParticipants       Int      @default(1)
  maxParticipants       Int?
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdById           String
  updatedById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  events                Event[]
  createdBy             User     @relation("InteractionTypeCreatedBy", fields: [createdById], references: [id])
  updatedBy             User     @relation("InteractionTypeUpdatedBy", fields: [updatedById], references: [id])

  @@index([isActive, sortOrder])
}

model Event {
  id                 String               @id @default(uuid())
  name               String
  description        String?
  offeringId         String
  interactionTypeId  String
  assignmentStrategy AssignmentStrategy   @default(DIRECT)
  durationSeconds    Int
  locationType       EventLocationType
  locationValue      String
  isActive           Boolean              @default(true)
  teamId             String
  createdById        String
  updatedById        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  publicBookingSlug  String               @unique
  bookings           Booking[]
  createdBy          User                 @relation("EventCreatedBy", fields: [createdById], references: [id])
  interactionType    EventInteractionType @relation(fields: [interactionTypeId], references: [id])
  offering           EventOffering        @relation(fields: [offeringId], references: [id])
  team               Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  updatedBy          User                 @relation("EventUpdatedBy", fields: [updatedById], references: [id])
  hosts              EventHost[]
  routingState       EventRoutingState?

  @@index([teamId, isActive])
  @@index([offeringId])
  @@index([interactionTypeId])
  @@index([assignmentStrategy])
}

model EventHost {
  id         String   @id @default(uuid())
  eventId    String
  hostUserId String
  hostOrder  Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hostUser   User     @relation("EventHostUser", fields: [hostUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, hostUserId])
  @@unique([eventId, hostOrder])
  @@index([hostUserId])
  @@index([eventId, isActive])
}

model EventRoutingState {
  id            String   @id @default(uuid())
  eventId       String   @unique
  nextHostOrder Int      @default(1)
  updatedAt     DateTime @updatedAt
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model UserWeeklyAvailability {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
}

model UserAvailabilityException {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime
  isUnavailable Boolean
  startTime     String?
  endTime       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Student {
  id            String    @id @default(uuid())
  fullName      String
  email         String    @unique
  firstBookedAt DateTime?
  lastBookedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]

  @@index([lastBookedAt])
}

model Booking {
  id                String        @id @default(uuid())
  studentId         String?
  studentName       String
  studentEmail      String
  teamId            String
  eventId           String
  hostUserId        String
  startTime         DateTime
  endTime           DateTime
  timezone          String        @default("UTC")
  notes             String?
  status            BookingStatus @default(CONFIRMED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  sessionObjectives String?
  specificQuestion  String?
  triedSolutions    String?
  usedResources     String?
  meetingJoinUrl    String?
  student           Student?      @relation(fields: [studentId], references: [id])
  event             Event         @relation(fields: [eventId], references: [id])
  host              User          @relation(fields: [hostUserId], references: [id])
  team              Team          @relation(fields: [teamId], references: [id])

  @@index([studentId])
  @@index([teamId])
  @@index([eventId])
  @@index([hostUserId])
  @@index([startTime, endTime])
}

enum UserRole {
  SUPER_ADMIN
  TEAM_ADMIN
  COACH
}

enum AssignmentStrategy {
  DIRECT
  ROUND_ROBIN
}

enum EventLocationType {
  VIRTUAL
  IN_PERSON
  CUSTOM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}
