# ---------------------------------------------------------
# DATABASE CONFIGURATION
# ---------------------------------------------------------
# Local: postgresql://user:pass@localhost:5432/chegg_db
# Production: use your managed Postgres connection string
DATABASE_URL="postgresql://user:pass@localhost:5432/chegg_db"

# ---------------------------------------------------------
# SERVER & SECURITY
# ---------------------------------------------------------
NODE_ENV="development"
PORT="4000"
JWT_SECRET="replace-this-with-a-long-random-secret"
JWT_EXPIRES_IN_SECONDS="86400"
COOKIE_SAME_SITE="lax"
ENABLE_CSRF_PROTECTION="false"
ALLOW_SELF_REGISTER="false"
BOOTSTRAP_SECRET="replace-this-bootstrap-secret"

# Comma-separated allowed frontend origins for credentialed CORS.
# Local: http://localhost:3000
# Production: https://your-frontend.example.com
CORS_ORIGINS="http://localhost:3000"

# Public URLs for deep links in emails and public booking flows
FRONTEND_URL="http://localhost:3000"
CLIENT_FRONTEND_URL="http://localhost:3000"

# ---------------------------------------------------------
# SSO / OIDC — Okta
# ---------------------------------------------------------
# Okta setup steps:
#   1. In your Okta admin console, go to Applications → Create App Integration
#   2. Choose OIDC - OpenID Connect, then Web Application
#   3. Add the redirect URI below to "Sign-in redirect URIs"
#   4. Copy the Client ID and Client Secret from the app's General tab
#   5. Set OIDC_ISSUER_URL to your Okta custom authorization server URL:
#      - Custom auth server (recommended): https://<your-okta-domain>/oauth2/default
#        or https://<your-okta-domain>/oauth2/<authServerId>
#      - Org auth server (legacy):         https://<your-okta-domain>
#   6. In Okta, assign users or groups to the app so they can sign in
#
# Leave OIDC_ISSUER_URL blank to disable SSO entirely.
OIDC_ISSUER_URL=""                                         # e.g. https://yourorg.okta.com/oauth2/default
OIDC_CLIENT_ID=""                                          # from Okta app General tab
OIDC_CLIENT_SECRET=""                                      # from Okta app General tab
OIDC_REDIRECT_URI="http://localhost:4000/api/auth/sso/callback"   # must match Okta app's redirect URI
OIDC_PROVIDER_NAME="okta"                                  # stored in DB to identify the provider

# ---------------------------------------------------------
# AUTH & APP POLICIES
# ---------------------------------------------------------
MAX_FAILED_LOGIN_ATTEMPTS="5"
LOGIN_LOCKOUT_MINUTES="15"
INVITE_EXPIRY_DAYS="7"

# Rate limiting
SENSITIVE_RATE_LIMIT_WINDOW_MS="300000"
SENSITIVE_RATE_LIMIT_MAX="100"
STANDARD_RATE_LIMIT_WINDOW_MS="900000"
STANDARD_RATE_LIMIT_MAX="1000"
STRICT_RATE_LIMIT_WINDOW_MS="900000"
STRICT_RATE_LIMIT_MAX="5"
ENABLE_RATE_LIMITS_IN_TEST="false"

# ---------------------------------------------------------
# NOTIFICATIONS (RABBITMQ)
# ---------------------------------------------------------
# Local: amqp://localhost (if running RabbitMQ locally)
# Production: use your managed RabbitMQ / AMQP URL
RABBITMQ_URL="amqp://localhost"
NOTIFICATIONS_ENABLED="true"
NOTIFICATION_EXCHANGE="notificationExchange"
NOTIFICATION_ROUTING_KEY="notification.send"

# ---------------------------------------------------------
# OBSERVABILITY
# ---------------------------------------------------------
LOG_LEVEL="info"
LOG_CLIENT_ERRORS="false"