DATABASE_URL="postgresql://postgres:12345@localhost:5432/chegg-scheduling-app-test?schema=public"
JWT_SECRET="test-jwt-secret-key-for-testing"
JWT_EXPIRES_IN_SECONDS="3600"
BOOTSTRAP_SECRET="test-bootstrap-secret-abc123"
ALLOW_SELF_REGISTER="false"
NODE_ENV="test"

# Raise rate-limit ceilings so repeated test calls don't hit 429
SENSITIVE_RATE_LIMIT_MAX="10000"
STANDARD_RATE_LIMIT_MAX="10000"
STRICT_RATE_LIMIT_MAX="10000"
